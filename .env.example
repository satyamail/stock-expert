# StockExpert - Local Security & Credentials Configuration
# Copy this file to '.env' and fill in your actual credentials.
# This file is gitignored and will never be committed to GitHub.

# --- SCREENER.IN AUTHENTICATION ---
SCREENER_EMAIL=your_email@example.com
SCREENER_PASSWORD=your_secure_password

# --- SCANNER CONFIGURATION ---
# Scanning interval in hours (e.g. 24 for daily, 168 for weekly)
SCAN_INTERVAL_HOURS=24
